# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# FFmpeg Path (usually not needed - Railway has it pre-installed)
# FFMPEG_PATH=/usr/bin/ffmpeg

# HenrikDev Valorant API Key — powers !vtl (and is the Riot-direct data source
# that works for private Tracker.gg profiles). Free key from the dashboard:
#   https://api.henrikdev.xyz/dashboard/  (join their Discord, then generate a key)
HENRIK_API_KEY=your_henrik_api_key_here
